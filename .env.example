# ─────────────────────────────────────────────────────────
# Diggerz — OAuth Environment Variables
# Copy this file to .env and fill in your credentials.
# ─────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create (or select) a project
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Add your domain to "Authorised JavaScript origins"
#    (e.g. http://localhost:5173 for local dev)
VITE_GOOGLE_CLIENT_ID=

# ── Reddit OAuth ──────────────────────────────────────────
# 1. Go to https://www.reddit.com/prefs/apps
# 2. Create a new app — choose type "installed app"
# 3. Set redirect URI to your app origin (e.g. http://localhost:5173)
# 4. Copy the client ID shown below the app name
VITE_REDDIT_CLIENT_ID=
VITE_REDDIT_REDIRECT_URI=http://localhost:5173

# ── Apple Sign In ─────────────────────────────────────────
# 1. Go to https://developer.apple.com/account/resources/identifiers
# 2. Create a Services ID (type: Sign In with Apple)
# 3. Enable "Sign In with Apple" and configure your domain + return URL
# 4. The Services ID identifier (e.g. com.example.diggerz) is your client ID
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=http://localhost:5173
